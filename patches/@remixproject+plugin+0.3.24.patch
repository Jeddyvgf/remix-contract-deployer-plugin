version: 2.1

executors:
  node-executor:
    docker:
      - image: cimg/node:18.17.0
    working_directory: ~/remix-contract-deployer-plugin

jobs:
  install-deps:
    executor: node-executor
    steps:
      - checkout
      - restore_cache:
          keys:
            - node-modules-v1-{{ checksum "package-lock.json" }}
      - run:
          name: Install dependencies and apply patches
          command: |
            npm ci
            npm run postinstall
      - save_cache:
          paths:
            - node_modules
diff --git a/node_modules/@remixproject/plugin/package.json b/node_modules/@remixproject/plugin/package.json
index cf6fa88..dd6216b 100644
--- a/node_modules/@remixproject/plugin/package.json
+++ b/node_modules/@remixproject/plugin/package.json
@@ -26,7 +26,7 @@
   },
   "license": "MIT",
   "gitHead": "ca5c69be64ec4eaf7fe5d1d362726e75cb3b5726",
-  "main": "src/index.js",
-  "typings": "src/index.d.ts",
+  "main": "index.js",
+  "typings": "index.d.ts",
   "peerDependencies": {}
 }
